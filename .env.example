# ──────────────────────────────────────────────────────────────────────────────
# AlpanCoin — Environment Variables
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a git (está en .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# Clave privada del deployer (con o sin prefijo 0x)
# ADVERTENCIA: usa una wallet exclusiva para despliegues, nunca la principal.
PRIVATE_KEY=0xTU_CLAVE_PRIVADA_AQUI

# ── BNB Chain Mainnet ─────────────────────────────────────────────────────────
# RPC público (puedes usar un nodo privado de Ankr, QuickNode, etc.)
BSC_MAINNET_RPC_URL=https://bsc-dataseed1.binance.org

# ── BNB Chain Testnet (solo para pruebas) ─────────────────────────────────────
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# API key de BscScan para verificar contratos (https://bscscan.com/myapikey)
BSCSCAN_API_KEY=TU_API_KEY_DE_BSCSCAN

# Precio inicial de BNB/USD con 8 decimales
# Ejemplo: $600 → 60000000000
BNB_USD_PRICE=60000000000

# Activar reporte de gas (true/false)
REPORT_GAS=false
